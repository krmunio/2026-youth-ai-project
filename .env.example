# ==============================================================
# APIM (Foundry Proxy) 경유 LLM/임베딩 호출용 환경변수
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#   cp .env.example .env
# ==============================================================
#
# Foundry Proxy 구조:
#   {APIM_BASE_URL}/{MODEL_NAME}/   ← 모델별로 경로가 분리됨
#
# 인증: HTTP 헤더 "api-key: {APIM_KEY}" (모든 모델 공통 키)
# 노출 API: chat.completions, responses, embeddings
# ==============================================================

# APIM Foundry Proxy 베이스 URL (모델명 없이 /foundry 까지)
APIM_BASE_URL=https://apim-foundryproxy-dev.azure-api.net/foundry

# 운영자가 발급해준 APIM 공통 키 (절대 공유 금지!)
APIM_KEY=여기에_발급받은_키_붙여넣기

# 사용할 모델명 (URL 경로에 그대로 들어감)
CHAT_MODEL=gpt-5.4
EMBEDDING_MODEL=text-embedding-3-small
VISION_MODEL=gpt-5.4

