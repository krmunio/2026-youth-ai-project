# ==============================================================
# APIM 경유 Azure OpenAI 호출용 환경변수 샘플
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#   cp .env.sample .env
# ==============================================================

# APIM 게이트웨이 엔드포인트 (뒤에 슬래시/경로 없이 호스트만)
AZURE_OPENAI_ENDPOINT=https://{apim name}.azure-api.net

# Azure OpenAI API 버전
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# 운영자가 발급해준 학생별 APIM Subscription Key (절대 공유 금지)
APIM_SUBSCRIPTION_KEY=여기에_발급받은_키_붙여넣기

# 사용할 배포 이름 (APIM Operation의 deployment-id)
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# 임베딩용 배포 (선택)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── session-05 openai_workshop.ipynb 용 변수 ──
API_KEY=여기에_발급받은_키_붙여넣기
ENDPOINT=https://{apim name}.azure-api.net/openai/
CHAT_DEPLOYMENT=gpt-4.1-mini
VISION_DEPLOYMENT=gpt-4.1-mini
EMBEDDING_ENDPOINT=https://{apim name}.azure-api.net/openai/
EMBEDDING_DEPLOYMENT=text-embedding-3-large
